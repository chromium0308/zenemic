# =============================================================================
# Zenemic — ONE env file for the WHOLE repo (backend services + Expo app)
# =============================================================================
# Copy this file to `.env.local` at the repo root and fill in real values.
# NEVER commit `.env.local`.
#
# Who reads what:
#   • backend (main-app + keyboard) — everything EXCEPT the EXPO_PUBLIC_* block.
#     Loaded + validated by packages/shared/src/config/env.ts.
#   • the Expo app (main-app/) — ONLY the EXPO_PUBLIC_* block, via
#     main-app/app.config.js. Backend secrets NEVER reach the app bundle.
#
# [REQUIRED] = backend won't boot without it. [OPTIONAL] = gates one integration;
# if unset, those endpoints return a clear "not configured" error instead of
# crashing, so you can bring features up one at a time.
# =============================================================================

# -----------------------------------------------------------------------------
# Core server (backend) — how the services run; safe defaults, rarely changed
# -----------------------------------------------------------------------------
NODE_ENV=development
# The two backend services share this file but listen on different ports.
MAIN_APP_PORT=4000
KEYBOARD_PORT=4100
# The main-app backend's OWN public URL — used to build the Google OAuth redirect
# and the Stripe webhook URL. Localhost is fine in dev; in prod use the real URL.
API_BASE_URL=http://localhost:4000
# CORS allow-list for a WEB client only — native phone requests ignore CORS, so
# for the Android app this effectively doesn't matter. Comma-separated, or '*'.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database — Supabase IS your PostgreSQL — [REQUIRED]
# -----------------------------------------------------------------------------
# The backend talks to Postgres directly via Prisma (the ORM), not the Supabase
# data API, so it needs raw connection strings. Same project as Auth below.
#   DATABASE_URL = POOLED url (6543) — all runtime queries.
#   DIRECT_URL   = DIRECT url (5432) — ONLY Prisma migrate/introspect.
# Supabase → "Connect" → ORMs / Prisma. Replace [PASSWORD]/[PROJECT-REF]/[REGION].
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Auth — Supabase Auth — [REQUIRED]
# -----------------------------------------------------------------------------
# Same Supabase project as the DB. The backend verifies the app's access token
# via Supabase's public JWKS (no secret needed for verification itself).
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# SECRET admin key — used for admin actions (e.g. deleting a user). Never ship to
# the client. Dashboard → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=
# Leave BLANK on modern projects (JWKS). Only set for LEGACY HS256 projects.
SUPABASE_JWT_SECRET=
# Your OWN random secret (NOT a Supabase key) — signs the short-lived Google OAuth
# "state" token (CSRF). Generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
APP_SECRET=

# -----------------------------------------------------------------------------
# Anthropic — the core AI — [REQUIRED]
# -----------------------------------------------------------------------------
# Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Optional cheaper model for ONLY the extraction step (e.g. claude-sonnet-4-6).
ANTHROPIC_EXTRACTION_MODEL=
ANTHROPIC_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Google Calendar — OAuth — [OPTIONAL]
# -----------------------------------------------------------------------------
# Lets a user connect Google so Zenemic creates calendar events + sends invites.
# Create a "Web application" OAuth client (the redirect lands on THIS backend) in
# Google Cloud → APIs & Services → Credentials; register the redirect URI below
# exactly. Scopes used: calendar.events, openid, email.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/google/callback

# -----------------------------------------------------------------------------
# Google Maps — API key — [OPTIONAL]
# -----------------------------------------------------------------------------
# Server-side geocoding (venue → coordinates) + transit/travel times. Maps deep
# links still work WITHOUT a key; you only lose geocoding + travel estimates.
# Google Cloud → enable "Geocoding API" + "Directions API" → create an API key
# (needs billing enabled; large free tier). Transit works globally incl. London —
# which is why Zenemic no longer needs a Transport-for-London key.
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Stripe — payment splitting — [OPTIONAL]
# -----------------------------------------------------------------------------
# The split flow creates a hosted Stripe Payment Link (a URL) per person; a
# webhook marks each share paid. Keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Verifies the webhook → https://dashboard.stripe.com/webhooks
# endpoint {API_BASE_URL}/api/webhooks/stripe, event checkout.session.completed
STRIPE_WEBHOOK_SECRET=
# Default event currency (also the AI's fallback). NOT sent to Stripe per call.
STRIPE_CURRENCY=eur
# Optional — only if you later embed Stripe's in-app SDK (hosted links don't need it).
STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Shared photo album — Supabase Storage (S3-compatible) — [OPTIONAL]
# -----------------------------------------------------------------------------
# The per-event shared album. NOTE: this is NOT Google Photos — Google removed
# shared-album API access in March 2025, so albums use object storage. Use your
# EXISTING Supabase project's Storage (no AWS needed):
#   Supabase → Storage → New bucket (e.g. "zenemic-albums")
#   Supabase → Project Settings → Storage → S3 access keys → generate
#   S3_ENDPOINT        = https://[PROJECT-REF].storage.supabase.co/storage/v1/s3
#   S3_PUBLIC_BASE_URL = https://[PROJECT-REF].storage.supabase.co/storage/v1/object/public/[BUCKET]
# (Leave S3_ENDPOINT blank to use real AWS S3 instead.)
S3_REGION=eu-west-2
S3_BUCKET=zenemic-albums
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Push notifications — Expo — [OPTIONAL]
# -----------------------------------------------------------------------------
# Wired: the backend notifies the event host when an attendee pays. Expo push
# works WITHOUT a token in dev; set EXPO_ACCESS_TOKEN only if you enable Expo's
# enhanced push security. Delivering to a real Android build also needs an EAS
# projectId + FCM credentials configured in the app (one-time Expo setup).
EXPO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Email — Resend — [OPTIONAL]
# -----------------------------------------------------------------------------
# Wired: emails each attendee their Stripe payment-link when a split is sent.
# (Auth emails — verification/reset — are sent by Supabase, not here.)
# Key: https://resend.com/api-keys . EMAIL_FROM must be a verified sender/domain.
RESEND_API_KEY=
EMAIL_FROM=Zenemic <no-reply@zenemic.app>

# =============================================================================
# Frontend (Expo app, main-app/) — ONLY these EXPO_PUBLIC_* values reach the app
# =============================================================================
# Where the app sends API requests:
#   • Physical Android phone (Expo Go): your PC's LAN IP — run `ipconfig`, IPv4.
#   • Android emulator: http://10.0.2.2:4000
#   • iOS simulator / web: http://localhost:4000
EXPO_PUBLIC_API_URL=http://192.168.1.100:4000
# Same Supabase project as SUPABASE_URL, but the PUBLIC anon key (client-safe).
EXPO_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
