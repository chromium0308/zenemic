# =============================================================================
# Zenemic backend — environment configuration
# =============================================================================
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# Keys marked [REQUIRED] must be set for the server to boot.
# Keys marked [OPTIONAL] gate a specific integration — if unset, that integration
# is disabled and the related endpoints return a clear "not configured" error
# instead of crashing. This lets you bring the backend up incrementally.
# =============================================================================

# -----------------------------------------------------------------------------
# Core server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
# Public base URL of THIS backend (used to build OAuth redirect + webhook URLs).
API_BASE_URL=http://localhost:4000
# Comma-separated list of allowed CORS origins (your Expo app / web client).
# Expo dev server is usually http://localhost:8081; use "*" only in development.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database — Supabase (PostgreSQL) — [REQUIRED]
# -----------------------------------------------------------------------------
# Supabase puts a connection pooler in front of Postgres. Prisma needs BOTH:
#   DATABASE_URL = the POOLED url (Transaction pooler, port 6543) for the app
#   DIRECT_URL   = a DIRECT url (Session pooler / direct, port 5432) for migrations
#
# Get these from the Supabase dashboard → "Connect" → ORMs / Prisma.
# Replace [PASSWORD], [PROJECT-REF], and [REGION] with your project's values.
#
# Pooled (runtime) — note the required ?pgbouncer=true. connection_limit=1 is
# recommended for serverless; raise/remove it for a long-running server.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Direct (migrations) — session pooler on 5432 (IPv4-friendly). You can instead
# use the true direct host db.[PROJECT-REF].supabase.co:5432 if your network has IPv6.
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Auth — Supabase Auth — [REQUIRED]
# -----------------------------------------------------------------------------
# Identity (signup/login/reset/MFA/OAuth) is handled by Supabase Auth on the
# client. The backend VERIFIES the Supabase access token on each request.
# From Supabase dashboard → Settings → API.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Service-role key — SECRET. Used for admin ops (delete user) + token checks.
# Never ship this to the client.
SUPABASE_SERVICE_ROLE_KEY=
# ONLY for legacy HS256 projects (Settings → API → JWT Secret). Leave BLANK to
# verify tokens via the project's JWKS (asymmetric keys — the modern default).
SUPABASE_JWT_SECRET=

# Internal secret for signing short-lived Google OAuth "state" tokens (not a
# Supabase value). Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
APP_SECRET=

# -----------------------------------------------------------------------------
# Anthropic — core AI [REQUIRED]
# -----------------------------------------------------------------------------
# Powers: natural-language event extraction, planner-chart generation,
# the "Ask Zenemic" chat assistant (tool use), and receipt itemisation (vision).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Default model. claude-opus-4-8 is the most capable; for cheaper/faster
# high-volume extraction you can switch to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-opus-4-8
# Optional: a cheaper/faster model for ONLY the high-volume extraction step.
# Leave blank to use ANTHROPIC_MODEL (opus) for everything. Set to
# claude-sonnet-4-6 if you want to trim cost on extraction.
ANTHROPIC_EXTRACTION_MODEL=
ANTHROPIC_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Google — Calendar (OAuth) + Maps (API key) [OPTIONAL]
# -----------------------------------------------------------------------------
# Calendar uses OAuth 2.0 so the app can create events on the user's own calendar.
# Create an OAuth client (type: Web) at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match a redirect URI registered on the OAuth client above.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/google/callback
# Maps Platform key (enable: Directions, Geocoding, Places). Separate from OAuth.
# https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Stripe — payment splitting [OPTIONAL]
# -----------------------------------------------------------------------------
# https://dashboard.stripe.com/apikeys  (use the test-mode keys while developing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# From the webhook endpoint you create at https://dashboard.stripe.com/webhooks
# (point it at {API_BASE_URL}/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=
# ISO 4217 currency for split requests (the design uses GBP; keyboard mocks use USD).
STRIPE_CURRENCY=gbp

# -----------------------------------------------------------------------------
# Transport for London — transit directions [OPTIONAL]
# -----------------------------------------------------------------------------
# Free key from https://api-portal.tfl.gov.uk/ — used for London public-transport
# journey links alongside Google Maps directions.
TFL_APP_KEY=

# -----------------------------------------------------------------------------
# Object storage (S3-compatible) — shared photo albums [OPTIONAL]
# -----------------------------------------------------------------------------
# Works with AWS S3, Cloudflare R2, Backblaze B2, MinIO — and Supabase Storage,
# which is S3-compatible. To use Supabase Storage (keeps everything in one place):
#   S3_ENDPOINT=https://[PROJECT-REF].storage.supabase.co/storage/v1/s3
#   S3_REGION=[your project region, e.g. eu-west-2]
#   S3_BUCKET=zenemic-albums  (create this bucket in the Supabase dashboard)
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = Storage → S3 access keys
#   S3_PUBLIC_BASE_URL=https://[PROJECT-REF].supabase.co/storage/v1/object/public/zenemic-albums
S3_REGION=eu-west-2
S3_BUCKET=zenemic-albums
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set S3_ENDPOINT for non-AWS providers (Supabase/R2/MinIO); leave blank for AWS S3.
S3_ENDPOINT=
# Public base URL for serving uploaded photos (CDN or bucket public URL).
S3_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Expo push notifications — reminders & RSVP nudges [OPTIONAL]
# -----------------------------------------------------------------------------
# Only needed if your Expo project has push security enabled.
# https://docs.expo.dev/push-notifications/sending-notifications/
EXPO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Transactional email — event invites & notifications [OPTIONAL]
# -----------------------------------------------------------------------------
# Auth emails (verification, password reset, magic links) are sent by Supabase
# Auth, not here. This is for app-level mail like event invites.
# Using Resend (https://resend.com/api-keys). Swap providers in
# src/integrations/email.ts if you prefer SMTP/SendGrid/Postmark.
RESEND_API_KEY=
EMAIL_FROM=Zenemic <no-reply@zenemic.app>
