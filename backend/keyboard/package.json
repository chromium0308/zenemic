{
  "name": "@zenemic/keyboard",
  "version": "0.1.0",
  "private": true,
  "description": "Zenemic keyboard backend — standalone service for the keyboard's POST /generate and POST /confirm.",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
