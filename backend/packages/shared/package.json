{
  "name": "@zenemic/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Prisma schema/client, Supabase auth, Anthropic AI, integrations and domain services for the Zenemic backend services.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@prisma/client": "^6.1.0",
    "@supabase/supabase-js": "^2.47.10",
    "dotenv": "^16.4.7",
    "expo-server-sdk": "^3.13.0",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "jose": "^5.9.6",
    "pino": "^9.5.0",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
