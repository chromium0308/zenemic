# Copy this file to `.env` and fill in real values, then restart Expo: `npx expo start -c`.
# These EXPO_PUBLIC_* vars are inlined into the app at build time.

# Backend API base URL. For a PHYSICAL PHONE (Expo Go), use your PC's LAN IP so the
# phone can reach the backend over Wi-Fi — find it with `ipconfig` (IPv4 Address).
# Do NOT use localhost for a real device. (Android emulator would use http://10.0.2.2:4000.)
EXPO_PUBLIC_API_URL=http://192.168.1.100:4000

# Supabase project — Dashboard -> Project Settings -> API.
# The ANON (public) key is client-safe; it is NOT the service-role key.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY
